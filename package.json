{
  "name": "electric-field-sim",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run dev:frontend",
    "build": "npm run build:frontend",
    "test": "node --test test/*.test.js",
    "test:engine:regression": "npm test",
    "dev:frontend": "vite --config frontend/vite.config.ts",
    "build:frontend": "vite build --config frontend/vite.config.ts",
    "build:edgeone": "npm run build:frontend && node scripts/build-edgeone.mjs --scene ./frontend/public/scenes/material-mock-particle.json --name embed",
    "package:embed": "npm run build:frontend && node scripts/embed-packager.mjs",
    "test:frontend": "vitest --config frontend/vite.config.ts run",
    "test:frontend:regression": "npm run test:frontend",
    "lint:frontend": "eslint \"frontend/src/**/*.ts\" \"frontend/test/**/*.ts\"",
    "typecheck:frontend": "tsc --noEmit -p frontend/tsconfig.json",
    "test:smoke": "playwright test -c frontend/playwright.config.ts --project=desktop-chromium frontend/e2e/core-path.spec.ts frontend/e2e/embed-protocol.spec.ts",
    "test:e2e": "playwright test -c frontend/playwright.config.ts",
    "test:e2e:phone": "playwright test -c frontend/playwright.config.ts --project=phone-chromium frontend/e2e/touch-core-path.spec.ts",
    "quality:all": "npm run lint:frontend && npm run typecheck:frontend && npm run test:engine:regression && npm run test:frontend:regression && npm run test:e2e",
    "profile:high-emission": "node scripts/profile-high-emission.mjs",
    "profile:expressions": "node scripts/profile-expressions.mjs",
    "profile:browser-render": "node scripts/profile-browser-render.mjs",
    "profile:browser-expressions": "node scripts/profile-browser-expressions.mjs",
    "verify:budgets": "node scripts/check-build-budget.mjs",
    "verify:budgets:target": "BUILD_BUDGET_MODE=target node scripts/check-build-budget.mjs",
    "verify:profiles:contracts": "node --test test/profile_report_contract.test.js test/high_emission_profile.test.js test/expression_binding_profile.test.js test/browser_render_profile.test.js test/browser_expression_ui_profile.test.js",
    "verify:profiles:budgets": "node scripts/check-profile-budgets.mjs",
    "release:gate": "npm run lint:frontend && npm run typecheck:frontend && npm run test:engine:regression && npm run test:frontend:regression && npm run build:frontend && npm run verify:budgets && npm run verify:profiles:contracts && npm run verify:profiles:budgets && npm run test:e2e",
    "quality:release": "npm run release:gate"
  },
  "dependencies": {
    "katex": "^0.16.33",
    "pinia": "^3.0.3",
    "vue": "^3.5.20",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.1",
    "@tailwindcss/postcss": "^4.1.12",
    "@types/node": "^25.3.2",
    "@typescript-eslint/parser": "^8.42.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.39.2",
    "jsdom": "^28.0.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.12",
    "typescript": "^5.9.2",
    "vite": "^7.1.3",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "rollup": "^4.59.0",
    "minimatch": "^9.0.7",
    "ajv": "^6.14.0"
  }
}
